{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Draft": {
      "title": "Draft",
      "description": "An autosaved draft",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "seconds": { "type": "number" },
        "wpm": { "type": "number" },
        "wordCount": { "type": "number" },
        "activeSessionId": { "type": "string" },
        "pinnedThoughts": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "updatedAt": { "type": "number" }
      },
      "required": ["userId", "content", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "drafts/{userId}": {
      "schema": "Draft",
      "description": "Autosaved drafts"
    }
  }
}
