# Sentry DSN for error monitoring
VITE_SENTRY_DSN=

# PostHog analytics (get key from posthog.com or self-hosted instance)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# Firebase Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_FIRESTORE_DATABASE_ID=
VITE_RECAPTCHA_SITE_KEY=
# Local dev: set to any string to get an App Check debug token printed in the
# browser console, then register it in Firebase Console → App Check → Debug tokens.
# VITE_APPCHECK_DEBUG_TOKEN=

# ─── Server-side AI routing (NOT Vite — set in Vercel env + Firebase Functions) ───
# OpenRouter API key. Vercel: env var. Functions: `firebase functions:secrets:set OPENROUTER_API_KEY`.
# OPENROUTER_API_KEY=
# Require a Firebase App Check token on /api/chat (Vercel only). "true" to enforce.
# APP_CHECK_ENFORCE=
# Override the OpenRouter model id (defaults to DeepSeek v4 flash).
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# ─── Firebase App Check (Vercel endpoint only) ───
# Cloud Functions use enforceAppCheck: true on the callable definition directly.
# For /api/chat set this to 'true' in Vercel env vars for production.
# Leave unset or 'false' for local development and testing.
# APP_CHECK_ENFORCE=true
