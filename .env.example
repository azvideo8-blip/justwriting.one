# Sentry DSN for error monitoring
VITE_SENTRY_DSN=

# PostHog analytics (get key from posthog.com or self-hosted instance)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# Firebase Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_FIRESTORE_DATABASE_ID=
VITE_RECAPTCHA_SITE_KEY=

# ─── Server-side AI routing (NOT Vite — set in Vercel env + Firebase Functions) ───
# Provider for AI calls: "openrouter" (default) or "gemini".
# AI_PROVIDER=openrouter
# OpenRouter API key. Vercel: env var. Functions: `firebase functions:secrets:set OPENROUTER_API_KEY`.
# OPENROUTER_API_KEY=
# Override the OpenRouter model id (defaults to DeepSeek v4 pro/flash depending on entrypoint).
# OPENROUTER_MODEL=deepseek/deepseek-v4-pro
# GEMINI_API_KEY stays configured as the fallback provider.
