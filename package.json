{
  "name": "justwriting-one",
  "private": true,
  "version": "0.7.49",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build --outDir dist && npx tsx scripts/prerender.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --max-warnings 0 --ignore-pattern \"public/**\"",
    "lint:changed": "FILES=$(git diff --name-only --diff-filter=ACMR origin/main -- '*.ts' '*.tsx' ':(exclude)functions/**' ':(exclude)scripts/**'); if [ -z \"$FILES\" ]; then echo 'lint:changed: no changed .ts/.tsx files vs origin/main'; else echo \"$FILES\" | NODE_OPTIONS=--max-old-space-size=6144 xargs eslint --max-warnings 0; fi",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:ci": "vitest run",
    "i18n:audit": "tsx scripts/i18n-audit.ts",
    "ci": "npm run typecheck && npm run lint && npm run test:ci"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.66",
    "@sentry/react": "^10.46.0",
    "ai": "^6.0.191",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.6.1",
    "file-saver": "^2.0.5",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.10.0",
    "fuse.js": "^7.4.2",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "minisearch": "^7.2.0",
    "motion": "^12.23.24",
    "p-limit": "^7.3.0",
    "posthog-js": "^1.376.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.15.1",
    "react-virtuoso": "^4.18.7",
    "recharts": "^3.8.0",
    "rehype-sanitize": "^6.0.0",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^5.3.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/file-saver": "^2.0.7",
    "@types/jszip": "^3.4.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vercel/node": "^5.8.6",
    "@vercel/static-config": "^3.4.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-istanbul": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fake-indexeddb": "^6.2.5",
    "firebase-tools": "^15.15.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.4.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "@vercel/node": {
      "undici": "^6.24.0",
      "ajv": "^8.18.0",
      "smol-toml": "^1.6.1"
    },
    "path-to-regexp": "^6.3.0",
    "minimatch": "^10.2.3",
    "uuid": "^11.1.1",
    "hono": "^4.12.25",
    "form-data": "^4.0.6"
  }
}
